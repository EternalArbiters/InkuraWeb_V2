# =============================
# Inkura (apps/web)
# =============================

# Neon / Postgres
# - DATABASE_URL: pooled (runtime)
# - DIRECT_URL:   direct (migrations)
DATABASE_URL=
DIRECT_URL=

# NextAuth
NEXTAUTH_SECRET=
# For local dev, you usually want http://localhost:3000
# For production (Vercel), set this to your public domain.
NEXTAUTH_URL="http://localhost:3000"

# Dev helper (optional)
# Shows reset token on UI after requesting password reset.
NEXT_PUBLIC_SHOW_RESET_TOKEN="1"

# OAuth providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# =============================
# Cloudflare R2 (S3-compatible)
# =============================
# You can use either:
# - R2_ENDPOINT (full endpoint), OR
# - R2_ACCOUNT_ID (then endpoint is derived automatically)
#
# Example endpoint format:
#   https://<accountId>.r2.cloudflarestorage.com
#
# IMPORTANT: Do NOT commit real credentials.

# R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET="inkura-prod"
R2_PUBLIC_BASE_URL="https://cdn.inkura.id"

# =============================
# Observability (optional)
# =============================
# Log level for server JSON logs: debug | info | warn | error
# In production, you usually want 'warn' or 'error'.
INKURA_LOG_LEVEL=info

# If set to '1', logs every API request (can be noisy).
INKURA_LOG_REQUESTS=

# Optional: service name label in logs
INKURA_SERVICE_NAME=
