# =============================
# Inkura (apps/web)
# Stage 10 final env example
# =============================
# Copy this file to: apps/web/.env.local
# Do NOT commit real credentials.

# -----------------------------
# Database (Neon / Postgres)
# -----------------------------
# DATABASE_URL = pooled runtime URL
# DIRECT_URL   = direct URL for migrations / schema operations
DATABASE_URL=
DIRECT_URL=

# -----------------------------
# Auth / app origin
# -----------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL="http://localhost:3000"

# Optional fallback used by server-side apiJson() when origin is not inferred
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional base URLs used by password reset flow
RESET_PASSWORD_URL_BASE="http://localhost:3000"
APP_BASE_URL="http://localhost:3000"

# Local/dev helper for forgot-password flow.
# Backend reads SHOW_RESET_TOKEN, not NEXT_PUBLIC_SHOW_RESET_TOKEN.
SHOW_RESET_TOKEN="1"

# -----------------------------
# OAuth providers (optional)
# -----------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# -----------------------------
# Email / password reset (optional)
# -----------------------------
RESEND_API_KEY=
EMAIL_FROM="Inkura <no-reply@example.com>"

# -----------------------------
# Cloudflare R2 (S3-compatible)
# -----------------------------
# Use one naming style below.
# Code also accepts CLOUDFLARE_R2_* aliases for legacy environments.

# Style A: explicit endpoint
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET="inkura-dev"
R2_PUBLIC_BASE_URL="https://cdn.example.test"

# Style B: account id + derived endpoint
# R2_ACCOUNT_ID=
# R2_BUCKET_NAME="inkura-dev"

# -----------------------------
# Observability (optional)
# -----------------------------
# debug | info | warn | error
INKURA_LOG_LEVEL=info

# Set to 1 to log every API request (can be noisy)
INKURA_LOG_REQUESTS=

# Optional service label in structured logs
INKURA_SERVICE_NAME=inkura-web

# -----------------------------
# Deploy preview behavior (optional)
# -----------------------------
# Set to 1 only if preview deploys use a dedicated preview DB
INKURA_MIGRATE_PREVIEW=

# -----------------------------
# Playwright smoke / E2E (optional)
# -----------------------------
PLAYWRIGHT_BASE_URL="http://127.0.0.1:3000"
E2E_ADMIN_EMAIL="noelephgoddess.game@gmail.com"
E2E_ADMIN_PASSWORD="admin123"
