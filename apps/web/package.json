{
  "name": "inkura-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "tailwind": "tailwindcss",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma db push --force-reset",
    "db:seed": "prisma generate && prisma db seed",
    "db:init": "npm run db:generate && npm run db:reset && npm run db:seed",
    "db:push": "prisma db push",
    "db:cleanup-taxonomy": "tsx prisma/cleanupTaxonomy.ts",
    "sanity:db": "tsx scripts/sanity-db.ts",
    "verify": "npm run prisma:validate && npm run db:generate && npm run typecheck && npm run build",
    "db:migrate:deploy": "prisma migrate deploy",
    "deploy:check-env": "node scripts/check-env.js",
    "vercel-build": "node scripts/vercel-build.js",
    "db:taxonomy-alpha": "tsx prisma/reorderTaxonomyAlphabetical.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@prisma/client": "6.19.2",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-visually-hidden": "^1.1.3",
    "@tailwindcss/line-clamp": "^0.4.4",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cropperjs": "^1.6.2",
    "framer-motion": "^12.9.2",
    "lucide-react": "^0.488.0",
    "next": "14.2.35",
    "next-auth": "^4.24.11",
    "react": "18.2.0",
    "react-easy-crop": "^5.4.2",
    "react-dom": "18.2.0",
    "react-icons": "^5.5.0",
    "tailwind-merge": "^3.2.0",
    "tailwind-variants": "^1.0.0",
    "tw-animate-css": "^1.2.5",
    "zustand": "^5.0.3",
    "sharp": "^0.34.1",
    "@aws-sdk/client-s3": "^3.835.0",
    "@aws-sdk/s3-request-presigner": "^3.835.0",
    "geist": "^1.7.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.4",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/node": "^20.17.32",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "shx": "^0.4.0",
    "tailwindcss": "^4.1.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "prisma": "6.19.2"
  }
}
