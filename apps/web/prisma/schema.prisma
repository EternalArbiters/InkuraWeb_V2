generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Auth ---
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String?  @unique
  password  String?
  name      String?
  image     String?
  // Avatar framing (object-position + scale) so user can adjust PP like WA/IG
  avatarFocusX Int?
  avatarFocusY Int?
  avatarZoom   Float?
  gender      UserGender?
  birthMonth  Int?
  birthYear   Int?
  analyticsOnboardingCompletedAt DateTime?
  demographicsUpdatedAt DateTime?
  role      Role     @default(USER)

  // Preferences
  adultConfirmed         Boolean @default(false)
  // Deviant Love (separate gate, locked by default)
  deviantLoveConfirmed   Boolean @default(false)
  preferredLanguagesJson String  @default("[]")

  // Content
  works      Work[]
  translatedWorks Work[] @relation("WorkTranslator")
  workSeries WorkSeries[]
  likes      WorkLike[]
  chapterLikes ChapterLike[]
  commentLikes CommentLike[]
  commentDislikes CommentDislike[]
  ratings    WorkRating[]
  bookmarks  Bookmark[]
  progress   ReadingProgress[]
  comments   Comment[]

  // Social graph
  following  FollowUser[] @relation("Following")
  followers  FollowUser[] @relation("Followers")

  // Notifications
  notifications Notification[]

  // Reading lists
  readingLists ReadingList[]

  // Reviews
  reviews Review[]
  reviewVotes ReviewVote[]

  // Moderation
  hiddenComments  Comment[] @relation("HiddenComments")
  pinnedComments  Comment[] @relation("PinnedComments")

  reportsMade     Report[]  @relation("ReportsMade")
  reportsResolved Report[]  @relation("ReportsResolved")

  // v14: user -> admin inbox reports
  adminInboxReportsMade     AdminInboxReport[] @relation("AdminInboxReportsMade")
  adminInboxReportsResolved AdminInboxReport[] @relation("AdminInboxReportsResolved")

  // v15: admin audit logs
  adminAuditLogs AdminAuditLog[]

  // Preference blocks
  blockedGenres    Genre[]      @relation("UserBlockedGenres")
  blockedWarnings  WarningTag[] @relation("UserBlockedWarnings")
  blockedDeviantLove DeviantLoveTag[] @relation("UserBlockedDeviantLove")

  // Auth
  passwordResetTokens PasswordResetToken[]

  // Analytics
  analyticsSessions AnalyticsSession[]
  analyticsEvents AnalyticsEvent[]
  analyticsDailyCreators AnalyticsDailyCreator[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  USER
}

enum UserGender {
  MALE
  FEMALE
  PREFER_NOT_TO_SAY
}

enum AnalyticsDeviceType {
  MOBILE
  TABLET
  DESKTOP
  BOT
  UNKNOWN
}

enum AnalyticsEventType {
  SESSION_SEEN
  PAGE_VIEW
  WORK_VIEW
  CHAPTER_VIEW
  BOOKMARK_ADD
  BOOKMARK_REMOVE
  WORK_LIKE
  CHAPTER_LIKE
  COMMENT_CREATE
  RATING_SUBMIT
  FOLLOW_USER
  SEARCH_SUBMIT
  SEARCH_RESULT_CLICK
  SIGNUP_COMPLETE
  LOGIN_SUCCESS
  PROFILE_ONBOARDING_COMPLETE
  WORK_PUBLISH
  CHAPTER_PUBLISH
  REPORT_CREATE
}

enum AnalyticsTrafficSource {
  DIRECT
  INTERNAL
  SEARCH
  SOCIAL
  EXTERNAL
  UNKNOWN
}

enum AnalyticsAgeBand {
  UNDER_18
  AGE_18_24
  AGE_25_34
  AGE_35_44
  AGE_45_PLUS
  UNKNOWN
}

enum WorkPublishType {
  ORIGINAL
  TRANSLATION
  REUPLOAD
}

// --- Content ---
enum WorkType {
  NOVEL
  COMIC
}

enum ComicType {
  UNKNOWN
  MANGA
  MANHWA
  MANHUA
  WEBTOON
  WESTERN
  OTHER
}

enum WorkStatus {
  DRAFT
  PUBLISHED
}



enum ChapterStatus {
  DRAFT
  PUBLISHED
}
enum WorkOrigin {
  UNKNOWN
  ORIGINAL
  FANFIC
  ADAPTATION
}

enum WorkCompletion {
  ONGOING
  COMPLETED
  HIATUS
  CANCELLED
}

model WorkSeries {
  id        String   @id @default(cuid())
  title     String
  slug      String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  works     Work[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, slug])
  @@index([ownerId, updatedAt])
}

model Work {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  subtitle    String?
  description String?
  type        WorkType
  comicType   ComicType  @default(UNKNOWN)
  status      WorkStatus @default(DRAFT)

  // Content meta
  isMature    Boolean        @default(false)
  language    String         @default("unknown")
  origin      WorkOrigin     @default(UNKNOWN)
  completion  WorkCompletion @default(ONGOING)

  // Publish meta (v12)
  publishType WorkPublishType @default(ORIGINAL)
  originalAuthorCredit String?
  originalTranslatorCredit String?
  sourceUrl String?
  uploaderNote String?

  // v16.3: additional credits + legacy arc links
  translatorCredit String?
  companyCredit String?
  prevArcUrl String?
  nextArcUrl String?

  // v17: full series management
  seriesId    String?
  series      WorkSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  seriesOrder Int?

  translatorId String?
  translator   User? @relation("WorkTranslator", fields: [translatorId], references: [id])

  // Cached counters (updated by API routes)
  likeCount   Int        @default(0)
  ratingAvg   Float      @default(0)
  ratingCount Int        @default(0)

  // Cached counts
  chapterCount Int       @default(0)

  coverImage  String?
  // v13 (R2): store object key for deletes / audit
  coverKey    String?

  // Taxonomy
  genres      Genre[]      @relation("WorkGenres")
  tags        Tag[]        @relation("WorkTags")
  warningTags WarningTag[] @relation("WorkWarnings")
  deviantLoveTags DeviantLoveTag[] @relation("WorkDeviantLove")

  authorId    String
  author      User       @relation(fields: [authorId], references: [id])

  chapters    Chapter[]

  likes       WorkLike[]
  ratings     WorkRating[]
  reviews     Review[]
  bookmarks   Bookmark[]
  progress    ReadingProgress[]

  readingListItems ReadingListItem[]

  analyticsEvents AnalyticsEvent[]
  analyticsDailyWorks AnalyticsDailyWork[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([authorId])
  @@index([type, status])
  @@index([status, isMature])
  @@index([language])
  @@index([publishType])
  @@index([translatorId])
  @@index([status, updatedAt])
  @@index([status, likeCount])
  @@index([status, type, updatedAt])
  @@index([status, type, likeCount])
  @@index([status, publishType, updatedAt])
  @@index([status, publishType, likeCount])
  @@index([status, ratingAvg, ratingCount, updatedAt])
  @@index([seriesId, seriesOrder])
}

model Chapter {
  id          String   @id @default(cuid())
  workId      String
  work        Work     @relation(fields: [workId], references: [id], onDelete: Cascade)

  number      Int
  label       String?
  title       String
  status      ChapterStatus @default(DRAFT)
  publishedAt DateTime?

  // Chapter-level meta
  isMature    Boolean        @default(false)
  warningTags WarningTag[]   @relation("ChapterWarnings")

  text        ChapterText?
  pages       ComicPage[]
  likeCount   Int @default(0)
  likes       ChapterLike[]
  readingProgresses ReadingProgress[]

  analyticsEvents AnalyticsEvent[]
  analyticsDailyChapters AnalyticsDailyChapter[]

  // v16.3: optional chapter thumbnail (cover) used in chapter list
  thumbnailImage String?
  thumbnailKey String?
  thumbnailFocusX Int?
  thumbnailFocusY Int?
  thumbnailZoom Float?

  // v16: optional message from uploader/author for this chapter
  authorNote String? @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workId, number])
  @@index([workId])
  @@index([workId, status, number, createdAt])
  @@index([status, publishedAt])
}

// --- Taxonomy ---
model Genre {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique

  // v15: admin-manageable taxonomy
  isActive  Boolean  @default(true)
  isSystem  Boolean  @default(true)
  isLocked  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  works     Work[]   @relation("WorkGenres")
  analyticsEvents AnalyticsEvent[]
  analyticsDailyGenres AnalyticsDailyGenre[]

  blockedByUsers User[] @relation("UserBlockedGenres")

  @@index([slug])
  @@index([isActive, sortOrder])
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique

  // v15: admin-manageable taxonomy
  isActive  Boolean  @default(true)
  isSystem  Boolean  @default(true)
  isLocked  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  works     Work[]   @relation("WorkTags")

  @@index([slug])
  @@index([isActive, sortOrder])
}

model WarningTag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique

  // v15: admin-manageable taxonomy
  isActive  Boolean  @default(true)
  isSystem  Boolean  @default(true)
  isLocked  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  works     Work[]    @relation("WorkWarnings")
  chapters  Chapter[] @relation("ChapterWarnings")

  blockedByUsers User[] @relation("UserBlockedWarnings")

  @@index([slug])
  @@index([isActive, sortOrder])
}

// --- Deviant Love (locked taxonomy) ---
model DeviantLoveTag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique

  // v15: admin-manageable taxonomy
  isActive  Boolean  @default(true)
  isSystem  Boolean  @default(true)
  isLocked  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  works     Work[]   @relation("WorkDeviantLove")
  blockedByUsers User[] @relation("UserBlockedDeviantLove")

  @@index([slug])
  @@index([isActive, sortOrder])
}

// v15: audit log for admin actions (taxonomy CRUD, etc.)
model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String

  // e.g. CREATE / UPDATE / DEACTIVATE / REACTIVATE / REORDER
  action    String
  // e.g. Genre / Tag / WarningTag / DeviantLoveTag
  entity    String
  entityId  String

  beforeJson Json?
  afterJson  Json?

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  admin     User @relation(fields: [adminId], references: [id], onDelete: Restrict)

  @@index([adminId, createdAt])
  @@index([entity, entityId, createdAt])
}

// --- Social ---
model WorkLike {
  userId    String
  workId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  work      Work   @relation(fields: [workId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, workId])
  @@index([workId])
  @@index([userId, createdAt])
}

model ChapterLike {
  userId    String
  chapterId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, chapterId])
  @@index([chapterId])
}

model WorkRating {
  userId    String
  workId    String
  value     Int
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  work      Work   @relation(fields: [workId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([userId, workId])
  @@index([workId])
}

model Bookmark {
  userId    String
  workId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  work      Work   @relation(fields: [workId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, workId])
  @@index([workId])
  @@index([userId, createdAt])
}

model ReadingProgress {
  id         String   @id @default(cuid())
  userId     String
  workId     String
  chapterId  String
  progress   Float?   // 0-1 (optional)
  lastReadAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  work       Work   @relation(fields: [workId], references: [id], onDelete: Cascade)
  chapter    Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
  @@index([workId])
  @@index([chapterId])
  @@index([userId, updatedAt])
  @@index([userId, lastReadAt])
}

enum CommentTargetType {
  WORK
  CHAPTER
}

enum CommentAttachmentType {
  IMAGE
  GIF
}

model Comment {
  id         String            @id @default(cuid())
  targetType CommentTargetType
  targetId   String
  userId     String
  body       String
  isSpoiler  Boolean           @default(false)
  // v16: threaded replies (Batoto-style)
  parentId   String?
  editedAt   DateTime?
  createdAt  DateTime          @default(now())
  likeCount  Int               @default(0)
  dislikeCount Int             @default(0)

  // v16.2: pinned/highlighted comment
  isPinned   Boolean           @default(false)
  pinnedAt   DateTime?
  pinnedById String?

  // Moderation
  isHidden   Boolean           @default(false)
  hiddenAt   DateTime?
  hiddenById String?

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[]         @relation("CommentReplies")
  hiddenBy    User?             @relation("HiddenComments", fields: [hiddenById], references: [id])
  pinnedBy   User?             @relation("PinnedComments", fields: [pinnedById], references: [id], onDelete: SetNull)
  attachments CommentAttachment[]
  likes       CommentLike[]
  dislikes    CommentDislike[]

  @@index([targetType, targetId, createdAt])
  @@index([targetType, targetId, parentId, createdAt])
  @@index([parentId])
  @@index([targetType, targetId, isPinned, pinnedAt])
  @@index([pinnedById])
  @@index([userId, createdAt])
}

model CommentAttachment {
  id        String                @id @default(cuid())
  commentId String
  mediaId   String
  type      CommentAttachmentType
  createdAt DateTime              @default(now())

  comment   Comment               @relation(fields: [commentId], references: [id], onDelete: Cascade)
  media     MediaObject           @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@unique([commentId, mediaId])
  @@index([commentId])
  @@index([mediaId])
}

model CommentLike {
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@index([commentId])

}

model CommentDislike {
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@index([commentId])
}

// --- Follow + Notifications ---
model FollowUser {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower   User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following  User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
}

enum NotificationType {
  NEW_WORK
  NEW_CHAPTER
  COMMENT_NEW
  COMMENT_REPLY
  COMMENT_MENTION
  COMMENT_PINNED
  ADMIN_MESSAGE
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  href      String

  // optional structured refs (v16.1)
  workId    String?
  chapterId String?
  actorId   String?
  // Prevent double notifications for the same event
  dedupeKey String?

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead, createdAt])
  @@unique([userId, dedupeKey])
  @@index([workId, createdAt])
  @@index([chapterId, createdAt])
}






// --- Reviews ---
model Review {
  id           String   @id @default(cuid())
  workId       String
  userId       String

  rating       Int
  title        String?
  body         String   @db.Text
  isSpoiler    Boolean  @default(false)

  helpfulCount Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  work         Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes        ReviewVote[]

  @@unique([workId, userId])
  @@index([workId, createdAt])
  @@index([workId, helpfulCount, createdAt])
  @@index([workId, rating, createdAt])
}

model ReviewVote {
  reviewId  String
  userId    String
  createdAt DateTime @default(now())

  review    Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([reviewId, userId])
  @@index([userId])
}

// --- Reading Lists / Collections ---
model ReadingList {
  id          String   @id @default(cuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  slug        String   @unique
  title       String
  description String?
  isPublic    Boolean  @default(false)

  items       ReadingListItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId, updatedAt])
  @@index([isPublic, updatedAt])
  @@index([ownerId, isPublic, updatedAt])
}

model ReadingListItem {
  id        String   @id @default(cuid())
  listId    String
  list      ReadingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  workId    String
  work      Work     @relation(fields: [workId], references: [id], onDelete: Cascade)

  sortOrder Int      @default(0)
  addedAt   DateTime @default(now())

  @@unique([listId, workId])
  @@index([listId, sortOrder])
  @@index([listId, addedAt])
  @@index([workId])
}

// --- Reports ---
enum ReportTargetType {
  COMMENT
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

model Report {
  id         String          @id @default(cuid())
  reporterId String
  targetType ReportTargetType
  targetId   String
  reason     String
  status     ReportStatus    @default(OPEN)
  createdAt  DateTime        @default(now())

  resolverId String?
  resolvedAt DateTime?
  note       String?

  reporter   User            @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  resolver   User?           @relation("ReportsResolved", fields: [resolverId], references: [id])

  @@index([status, createdAt])
  @@index([targetType, targetId])
}

// v14: user can send a message/report to admin (inbox).
model AdminInboxReport {
  id        String     @id @default(cuid())
  title     String
  message   String
  pageUrl   String?
  status    ReportStatus @default(OPEN)

  reporterId String
  reporter   User       @relation("AdminInboxReportsMade", fields: [reporterId], references: [id])

  resolverId String?
  resolver   User?      @relation("AdminInboxReportsResolved", fields: [resolverId], references: [id])

  resolvedAt DateTime?
  adminNote  String?

  reporterReadAt DateTime?
  adminReadAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([reporterId, createdAt])
}

// NOVEL content
model ChapterText {
  id        String   @id @default(cuid())
  chapterId String   @unique
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  content   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// COMIC pages
model ComicPage {
  id        String   @id @default(cuid())
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  order     Int
  imageUrl  String
  // v13 (R2): store object key for deletes / audit
  imageKey  String?

  createdAt DateTime @default(now())

  @@unique([chapterId, order])
  @@index([chapterId])
}

model AnalyticsSession {
  id            String   @id @default(cuid())
  userId        String?
  sessionKey    String   @unique
  ipHash        String?
  userAgentHash String?
  countryCode   String?
  deviceType    AnalyticsDeviceType @default(UNKNOWN)

  startedAt     DateTime @default(now())
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  events        AnalyticsEvent[]

  @@index([userId, lastSeenAt])
  @@index([startedAt])
  @@index([lastSeenAt])
  @@index([countryCode, lastSeenAt])
  @@index([deviceType, lastSeenAt])
}

model AnalyticsEvent {
  id              String   @id @default(cuid())
  occurredAt      DateTime @default(now())
  eventType       AnalyticsEventType

  userId          String?
  sessionId       String?
  sessionKey      String?
  isAuthenticated Boolean  @default(false)

  ipHash          String?
  userAgentHash   String?
  countryCode     String?
  deviceType      AnalyticsDeviceType @default(UNKNOWN)

  path            String?
  routeName       String?
  referrer        String?
  trafficSource   AnalyticsTrafficSource @default(UNKNOWN)

  workId          String?
  chapterId       String?
  genreId         String?
  actorUserId     String?
  ownerUserId     String?

  workType            WorkType?
  publishType         WorkPublishType?
  comicType           ComicType?
  workOrigin          WorkOrigin?
  translationLanguage String?
  isMature            Boolean?
  isDeviantLove       Boolean?

  searchQuery         String?
  searchType          String?
  resultCount         Int?

  metadata            Json?

  createdAt           DateTime @default(now())

  user                User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  session             AnalyticsSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  work                Work?             @relation(fields: [workId], references: [id], onDelete: SetNull)
  chapter             Chapter?          @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  genre               Genre?            @relation(fields: [genreId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([eventType, occurredAt])
  @@index([userId, occurredAt])
  @@index([sessionId, occurredAt])
  @@index([workId, occurredAt])
  @@index([chapterId, occurredAt])
  @@index([genreId, occurredAt])
  @@index([ownerUserId, occurredAt])
  @@index([searchQuery, occurredAt])
  @@index([eventType, workId, occurredAt])
  @@index([eventType, chapterId, occurredAt])
}

model AnalyticsDailyOverview {
  date              DateTime @id
  uniqueVisitors    Int      @default(0)
  activeUsers       Int      @default(0)
  guestVisitors     Int      @default(0)
  newUsers          Int      @default(0)
  pageViews         Int      @default(0)
  workViews         Int      @default(0)
  chapterViews      Int      @default(0)
  bookmarkAdds      Int      @default(0)
  bookmarkRemoves   Int      @default(0)
  workLikes         Int      @default(0)
  chapterLikes      Int      @default(0)
  commentsCreated   Int      @default(0)
  ratingsSubmitted  Int      @default(0)
  followsCreated    Int      @default(0)
  searches          Int      @default(0)
  reportsCreated    Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AnalyticsDailyGenre {
  date             DateTime
  genreId          String
  uniqueViewers    Int      @default(0)
  workViews        Int      @default(0)
  chapterViews     Int      @default(0)
  bookmarkAdds     Int      @default(0)
  likes            Int      @default(0)
  comments         Int      @default(0)
  ratingsCount     Int      @default(0)
  ratingSum        Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  genre            Genre    @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([date, genreId])
  @@index([genreId, date])
}

model AnalyticsDailyWork {
  date              DateTime
  workId            String
  uniqueViewers     Int      @default(0)
  views             Int      @default(0)
  chapterViews      Int      @default(0)
  bookmarkAdds      Int      @default(0)
  likes             Int      @default(0)
  comments          Int      @default(0)
  ratingsCount      Int      @default(0)
  ratingSum         Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  work              Work     @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@id([date, workId])
  @@index([workId, date])
  @@index([date, views])
  @@index([date, uniqueViewers])
}

model AnalyticsDailyChapter {
  date             DateTime
  chapterId        String
  uniqueViewers    Int      @default(0)
  views            Int      @default(0)
  likes            Int      @default(0)
  comments         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  chapter          Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@id([date, chapterId])
  @@index([chapterId, date])
  @@index([date, views])
}

model AnalyticsDailyCreator {
  date              DateTime
  userId            String
  publishedWorks    Int      @default(0)
  publishedChapters Int      @default(0)
  uniqueViewers     Int      @default(0)
  workViews         Int      @default(0)
  chapterViews      Int      @default(0)
  bookmarkAdds      Int      @default(0)
  likes             Int      @default(0)
  comments          Int      @default(0)
  followersGained   Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([date, userId])
  @@index([userId, date])
  @@index([date, uniqueViewers])
