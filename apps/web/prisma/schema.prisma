model AnalyticsDailyDemographic {
  id               String   @id @default(cuid())
  date             DateTime
  gender           UserGender?
  ageBand          AnalyticsAgeBand
  uniqueUsers      Int      @default(0)
  workViews        Int      @default(0)
  chapterViews     Int      @default(0)
  bookmarkAdds     Int      @default(0)
  likes            Int      @default(0)
  comments         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([date, gender, ageBand])
  @@index([date, uniqueUsers])
}

enum MediaObjectType {
  COMMENT_IMAGE
  COMMENT_GIF
}

// v16: de-duplicated media objects (by sha256). Used for comment attachments (image/gif).
model MediaObject {
  id          String         @id @default(cuid())
  sha256      String         @unique
  type        MediaObjectType
  contentType String
  sizeBytes   Int
  key         String
  url         String
  createdAt   DateTime       @default(now())

  // Opposite relation for CommentAttachment.media
  commentAttachments CommentAttachment[]

  @@index([type, createdAt])
  @@index([contentType, createdAt])
}


// For "Forgot password" flow (Credentials users).
model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}