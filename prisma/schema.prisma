generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String?
  name      String?
  image     String?   // ✅ tambahkan ini
  role      Role      // enum
  adultConfirmed Boolean @default(false)
  works     Work[]
  reports   Report[]
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  USER
}

model Work {
  id           String           @id @default(cuid())
  title        String
  description  String
  type         WorkType
  genres       String           @default("") // CSV sederhana: "fantasy,romance"
  nsfw         Boolean          @default(false)
  postingRole  ContributionRole @default(AUTHOR)
  coverDataUrl String?
  coverMime    String?

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id         String       @id @default(cuid())
  message    String
  status     ReportStatus @default(OPEN)
  createdAt  DateTime     @default(now())

  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id])
}

enum WorkType {
  NOVEL
  COMIC
  FILM
}

enum ContributionRole {
  AUTHOR
  TRANSLATOR
  REUPLOADER
}

enum ReportStatus {
  OPEN
  REVIEWED
  CLOSED
}
